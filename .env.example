# Song Generation Strategy Configuration
# Set to 'mock' for offline testing (instant, deterministic results)
# Set to 'suno' for real Suno API integration (requires SUNO_API_KEY)
GENERATOR_STRATEGY=mock

# Suno API Key - Required only if GENERATOR_STRATEGY=suno
# Get your key from: https://api.sunoapi.org/
# Leave blank or commented if using mock strategy
SUNO_API_KEY=
